<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title> APIs de los Mapas </title>

  <link rel="stylesheet" href="/css/styles.css"/>

  <!-- Leaflet -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
</head>

<body data-initial="<%= initialLocationJSON %>">
  <div class="app">

    <!-- HERO HEADER (MEJORADO) -->
    <header class="hero hero-color">
      <div class="hero-bg"></div>
      <div class="hero-glow"></div>

      <div class="hero-inner">
        <div class="hero-left">
          <div class="hero-kicker">JOSE LUIS BERNABE RODRIGUEZ </div>

          <div class="hero-title-row">
            <h1 class="hero-title">Comparación de APIs de Maps</h1>
            <span class="hero-pill-ghost">Google + OpenStreetMap</span>
          </div>

          <p class="hero-sub">
            Propietario vs Open Source. Geocoding completo, búsquedas enfocadas en México, sin límites de API key.
          </p>

          <div class="hero-badges">
            <span class="hero-chip">Satélite</span>
            <span class="hero-chip">Relieve</span>
            <span class="hero-chip">Click & Drag</span>
            <span class="hero-chip">Historial</span>
            <span class="hero-chip">Favoritos</span>
            <span class="hero-chip">Export</span>
          </div>
        </div>

        <div class="hero-right">
          <div class="hero-side">
            <div class="hero-side-top">
              <div class="pill hero-pill">
                <span class="dot"></span>
                <span>localhost</span>
              </div>

              <div class="hero-mini">
                <div class="hero-mini-label">Estado</div>
                <div class="hero-mini-value">Online</div>
              </div>
            </div>

            <div class="hero-side-bottom">
              <div class="hero-stat">
                <div class="hero-stat-label">Modo</div>
                <div class="hero-stat-value">Comparativo</div>
              </div>
              <div class="hero-stat">
                <div class="hero-stat-label">Región</div>
                <div class="hero-stat-value">México</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- PANEL TOP -->
    <section class="panel">
      <!-- Buscar -->
      <div class="card">
        <div class="card-head">
          <h2>Buscar ubicación</h2>
          <span class="badge blue">Geocoding</span>
        </div>

        <label class="label">Dirección / Lugar</label>

        <div class="search-row">
          <div class="autocomplete search-grow">
            <input
              id="searchInput"
              class="input input-lg"
              type="text"
              placeholder="Ej: Xicotepec, Liquidámbar 19 - Xicotepec, Puebla ..."
            />
          </div>
          <button id="btnSearch" class="btn primary btn-lg">Buscar</button>
        </div>

        <div class="hint">
          Tip: Presiona <b>Enter</b> para buscar.
        </div>
      </div>

      <!-- Coordenadas -->
      <div class="card">
        <div class="card-head">
          <h2>Ir a coordenadas</h2>
          <span class="badge green">Lat / Lng</span>
        </div>

        <div class="grid2">
          <div>
            <label class="label">Latitud</label>
            <input id="latInput" class="input" type="number" step="0.000001" value="<%= initialLocation.lat %>" />
          </div>
          <div>
            <label class="label">Longitud</label>
            <input id="lngInput" class="input" type="number" step="0.000001" value="<%= initialLocation.lng %>" />
          </div>
        </div>

        <div class="row">
          <button id="btnGoCoords" class="btn">Ir</button>
          <button id="btnMyLocation" class="btn">Mi ubicación</button>
        </div>

        <div class="card mini">
          <div class="mini-title">Coordenadas actuales</div>
          <div id="currentCoords" class="mini-value">Lat: <%= initialLocation.lat %> | Lng: <%= initialLocation.lng %></div>
          <div id="currentAddress" class="mini-sub"><%= initialLocation.name %></div>

          <div class="row mt10">
            <button id="btnSavePoint" class="btn primary">Guardar punto</button>
            <button id="btnToggleFavorite" class="btn">☆ Favorito</button>
          </div>
        </div>
      </div>
    </section>

    <!-- PANEL: HISTORIAL / FAVORITOS -->
    <section class="panel">
      <div class="card">
        <div class="card-head">
          <h2>Historial de búsquedas</h2>
          <span class="badge">localStorage</span>
        </div>
        <div id="historyList" class="list"></div>
        <div class="row mt10">
          <button id="btnClearHistory" class="btn">Limpiar historial</button>
        </div>
      </div>

      <div class="card">
        <div class="card-head">
          <h2>Favoritos</h2>
          <span class="badge">localStorage</span>
        </div>
        <div id="favoritesList" class="list"></div>
        <div class="row mt10">
          <button id="btnClearFavorites" class="btn">Limpiar favoritos</button>
        </div>
      </div>
    </section>

    <!-- PANEL: ANÁLISIS -->
    <section class="panel">
      <div class="card">
        <div class="card-head">
          <h2>Análisis de datos</h2>
          <span class="badge green">Análisis de Datos</span>
        </div>

        <div class="grid2">
          <div class="mini">
            <div class="mini-title">Distancia (últimos 2 puntos guardados)</div>
            <div id="distanceValue" class="mini-value">—</div>
            <div class="mini-sub">Tip: Presiona “Guardar punto” en 2 ubicaciones.</div>
          </div>

          <div class="mini">
            <div class="mini-title">Área de cobertura</div>
            <div class="row">
              <input id="coverageRadius" class="input" type="number" min="50" step="50" value="500" />
              <span class="muted">m</span>
            </div>
            <div class="row mt10">
              <button id="btnToggleCoverage" class="btn">Mostrar cobertura</button>
            </div>
          </div>
        </div>

        <div class="card mini mt10">
          <div class="mini-title">Exportar datos (puntos guardados)</div>
          <div class="row mt10">
            <button id="btnExportJSON" class="btn">Export JSON</button>
            <button id="btnExportCSV" class="btn">Export CSV</button>
            <button id="btnExportGeoJSON" class="btn">Export GeoJSON</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-head">
          <h2>Acciones rápidas</h2>
          <span class="badge">Atajos</span>
        </div>

        <div class="quick-grid">
          <button class="quick" id="btnQuickSave">Guardar punto</button>
          <button class="quick" id="btnQuickFav">Marcar favorito</button>
          <button class="quick" id="btnQuickExport">Export JSON</button>
          <button class="quick" id="btnQuickCoverage">Cobertura</button>
        </div>

        <div class="hint">Estos botones llaman a los mismos controles del panel.</div>
      </div>
    </section>

    <!-- MAPS -->
    <section class="maps">
      <!-- GOOGLE -->
      <div class="map-card">
        <div class="map-card-head">
          <div>
            <h3>Google Maps</h3>
            <p>Street View split + resize</p>
          </div>
          <div class="badge blue">PROPIETARIO</div>
        </div>

        <div class="map-toolbar">
          <button id="btnGoogleRoad" class="chip active">Normal</button>
          <button id="btnGoogleSat" class="chip">Satélite</button>
          <button id="btnGoogleTer" class="chip">Relieve</button>

          <div class="toolbar-spacer"></div>

          <button id="btnPegman" class="chip">Street View</button>
          <button id="btnClosePano" class="chip hidden">Cerrar</button>
        </div>

        <div class="gm-split">
          <div id="googleMap" class="map gm-map"></div>
          <div id="gmResizer" class="gm-resizer hidden" title="Arrastra para cambiar tamaño"></div>
          <div id="googlePano" class="map gm-pano hidden"></div>
        </div>

        <div class="pano-actions">
          <span id="gmapsMsg" class="pano-msg"></span>
        </div>
      </div>

      <!-- LEAFLET -->
      <div class="map-card">
        <div class="map-card-head">
          <div>
            <h3>Leaflet.js</h3>
            <p>OSM + Esri + Relieve</p>
          </div>
          <div class="badge green">OPEN SOURCE</div>
        </div>

        <div class="map-toolbar">
          <button id="btnLeafRoad" class="chip active">Normal</button>
          <button id="btnLeafSat" class="chip">Satélite</button>
          <button id="btnLeafTer" class="chip">Relieve</button>
        </div>

        <div id="leafletMap" class="map"></div>
      </div>
    </section>

    <!-- TABLA -->
    <section class="wide">
      <div class="card wide-card">
        <div class="card-head">
          <h2>Comparativa rápida</h2>
          <span class="badge">Tabla</span>
        </div>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Característica</th>
                <th>Google Maps</th>
                <th>Leaflet</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Licencia</td><td>Propietaria</td><td>Open Source</td></tr>
              <tr><td>Street View</td><td>✅ Sí (split + resize)</td><td>❌ No nativo</td></tr>
              <tr><td>Capas / tiles</td><td>✅ Integrado</td><td>✅ Proveedor (OSM/Esri/OpenTopo)</td></tr>
              <tr><td>Autocomplete</td><td>✅ Places (MX)</td><td>✅ Alternativas</td></tr>
              <tr><td>Historial/Favoritos</td><td>✅ localStorage</td><td>✅ localStorage</td></tr>
            </tbody>
          </table>
        </div>

        <div class="hint">
          Click en cualquiera de los mapas para actualizar coordenadas y dirección (reverse-geocode).
        </div>
      </div>
    </section>

    <footer class="footer">
      <span>Jose Luis Bernabe Rodriguez</span>
    </footer>
  </div>

  <!-- Leaflet JS -->
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script>window.__INITIAL__ = JSON.parse(document.body.dataset.initial);</script>

  <script src="/js/app.js"></script>

  <!-- Google Maps -->
  <script
    src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&v=weekly&libraries=places&callback=initGoogleMap"
    async
    defer
  ></script>

  <!-- Quick actions -->
  <script>
    document.getElementById("btnQuickSave")?.addEventListener("click", () => document.getElementById("btnSavePoint")?.click());
    document.getElementById("btnQuickFav")?.addEventListener("click", () => document.getElementById("btnToggleFavorite")?.click());
    document.getElementById("btnQuickExport")?.addEventListener("click", () => document.getElementById("btnExportJSON")?.click());
    document.getElementById("btnQuickCoverage")?.addEventListener("click", () => document.getElementById("btnToggleCoverage")?.click());
  </script>
</body>
</html>
